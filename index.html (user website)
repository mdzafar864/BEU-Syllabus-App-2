      "3rdOld": { "CE": "https://drive.google.com/file/d/1IS4EV9JvOfoLW3cYRW7U-qBkXyRAvFlD/preview", "CS": "https://drive.google.com/file/d/1ZlU22NFGirTuV01jKYiG9zdSU_IO29-t/preview", "EE": "https://drive.google.com/file/d/1D2gAZlW299s9f60wcdicGSZK7DpZVXkc/preview", "ECE": "https://drive.google.com/file/d/1auOpeh5UX4E23rnxIQo1K9TdFrqSXrm0/preview", "ME": "https://drive.google.com/file/d/1XE_l1tfHGZHMDIxU6KNlcjlqiKxKN-ZW/preview" },
      "4th": { "CE": "https://drive.google.com/file/d/17w5zTFNaWUOg7S_vUrqW_AxtMyf7bPdU/preview", "CS": "https://drive.google.com/file/d/1ODCj6Omx6dUuHR-Cmwh4iu37TaMQyTLn/preview", "EE": "https://drive.google.com/file/d/1G-cJOckwjZRoaDz0Nnw-CphpqBcZztA7/preview", "ECE": "https://drive.google.com/file/d/1nkfp0xRno6_ybJSWqZ6_ryiwI4aNsjXh/preview", "ME": "https://drive.google.com/file/d/1jVvYbUmth-RIbhLBXbDf3ooB8zgz8fSc/preview" },
      "5th": { "CE": "https://drive.google.com/file/d/1tGXDItZ5g-AsnsXN0KmMifbA36vgxA0C/preview", "CS": "https://drive.google.com/file/d/1SZdAT8a1vrIfrMPYjl0Q-0cc3hBba3z3/preview", "EE": "https://drive.google.com/file/d/1MA_tDBF7Fuvg8OGgn8bzg4mHSUTmQ-dC/preview", "ECE": "https://drive.google.com/file/d/1dJV_E7tPdhmmA7IutIDeaDMz3rxYb9XR/preview", "ME": "https://drive.google.com/file/d/1FW1-YDLvthfdG52szzsLzTIU9DOI03bc/preview" },
      "6th": { "CE": "https://drive.google.com/file/d/1MxzSoTSdMgCvgCPiDFsDjVuu4QaJCQge/preview", "CS": "https://drive.google.com/file/d/1ckXxGY5kdHmxlAIGsq-NfDskA4Mj_xQj/preview", "EE": "https://drive.google.com/file/d/1obhgEQmyRzDg1XPG7Gc6u5SyMugXN9bn/preview", "ECE": "https://drive.google.com/file/d/1reUmWqura-4UnEx7tpjv6wANADxvW_lc/preview", "ME": "https://drive.google.com/file/d/19UDBkvdYqgMqRzV_Fgre8vq8utOapy2q/preview" },
      "7th": { "CE": "https://drive.google.com/file/d/1Qy64E3CCdfhQvD8PaihwPDFVz2FwDqGr/preview", "CS": "https://drive.google.com/file/d/1uW4HVIaLErhWIyj36Lday4JMH1ZfuLEp/preview", "EE": "https://drive.google.com/file/d/1ey1jhsveL-eO0gc0FgwlNs7U05qRQHp5/preview", "ECE": "https://drive.google.com/file/d/1aDSSzOz8kWsmO0oJV7Z5CZ2lnCXReEqq/preview", "ME": "https://drive.google.com/file/d/1kMv43ZFJMctH_iRYbI230GCNN4UkZYud/preview" },
      "8th": { "EE": "https://drive.google.com/file/d/1BwL_f3KCmWzuEulEth3G3hQw5sxLvBOy/preview", "ME": "https://drive.google.com/file/d/1PPkfTohITDMkIFNuw836gSOSUjCFtt3n/preview" }
    };
    
    // Load from localStorage or use default
    let syllabusDB = JSON.parse(localStorage.getItem('beu_syllabus_db'));
    if (!syllabusDB) {
        syllabusDB = JSON.parse(JSON.stringify(DEFAULT_SYLLABUS));
        localStorage.setItem('beu_syllabus_db', JSON.stringify(syllabusDB));
    }
    
    // Helper: Save DB to localStorage and refresh UI
    function persistAndRefresh() {
        localStorage.setItem('beu_syllabus_db', JSON.stringify(syllabusDB));
        renderAdminTable();
        // Also update any viewer message reference
    }
    
    // Render table in admin panel
    function renderAdminTable() {
        const tbody = document.getElementById('tableBody');
        if (!tbody) return;
        let rows = '';
        const sortedSemesters = Object.keys(syllabusDB).sort();
        for (let sem of sortedSemesters) {
            const branches = syllabusDB[sem];
            for (let branch of Object.keys(branches)) {
                const link = branches[branch];
                rows += `<tr>
                    <td><span class="badge">${sem}</span></td>
                    <td><strong>${branch}</strong></td>
                    <td style="max-width:280px; overflow:hidden; text-overflow:ellipsis;"><a href="${link}" target="_blank">${link.substring(0, 65)}...</a></td>
                    <td>
                        <button class="edit-link" data-sem="${sem}" data-branch="${branch}" data-link="${link}">✏️ Edit</button>
                        <button class="del-link" data-sem="${sem}" data-branch="${branch}">🗑️ Delete</button>
                    </td>
                </tr>`;
            }
        }
        if (rows === '') tbody.innerHTML = '<tr><td colspan="4">No syllabus entries found. Add via form.</td></tr>';
        else tbody.innerHTML = rows;
        
        // attach event listeners to dynamic buttons
        document.querySelectorAll('.edit-link').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const sem = btn.getAttribute('data-sem');
                const branch = btn.getAttribute('data-branch');
                const link = btn.getAttribute('data-link');
                document.getElementById('adminSem').value = sem;
                document.getElementById('adminBranch').value = branch;
                document.getElementById('pdfUrlInput').value = link;
                showAdminMsg(`📝 Editing: ${sem} - ${branch}. Update URL and click Save.`, '#cffafe');
            });
        });
        document.querySelectorAll('.del-link').forEach(btn => {
            btn.addEventListener('click', () => {
                const sem = btn.getAttribute('data-sem');
                const branch = btn.getAttribute('data-branch');
                if (confirm(`Delete syllabus for ${sem} - ${branch}?`)) {
                    if (syllabusDB[sem] && syllabusDB[sem][branch]) {
                        delete syllabusDB[sem][branch];
                        if (Object.keys(syllabusDB[sem]).length === 0) delete syllabusDB[sem];
                        persistAndRefresh();
                        showAdminMsg(`✅ Deleted ${sem} / ${branch}`, '#dcfce7');
                    } else {
                        showAdminMsg(`⚠️ Entry not found.`, '#ffe4e2');
                    }
                }
            });
        });
    }
    
    function showAdminMsg(msg, bg = '#e6f7e6') {
        const div = document.getElementById('adminMsg');
        div.style.backgroundColor = bg;
        div.innerHTML = msg;
        setTimeout(() => { if(div) div.innerHTML = ''; }, 3500);
    }
    
    // Save/Update PDF from admin
    function savePdfEntry() {
        const sem = document.getElementById('adminSem').value;
        const branch = document.getElementById('adminBranch').value;
        let url = document.getElementById('pdfUrlInput').value.trim();
        if (!sem || !branch) { showAdminMsg('❌ Please select both Semester and Branch!', '#ffe0e0'); return; }
        if (!url) { showAdminMsg('❌ Please enter a valid PDF embed link.', '#ffe0e0'); return; }
        if (!url.startsWith('http')) { showAdminMsg('❌ Link must start with http/https', '#ffe0e0'); return; }
        if (!syllabusDB[sem]) syllabusDB[sem] = {};
        syllabusDB[sem][branch] = url;
        persistAndRefresh();
        showAdminMsg(`✅ Successfully updated ${sem} → ${branch}`, '#ccf0c3');
        document.getElementById('pdfUrlInput').value = '';
    }
    
    function deletePdfEntry() {
        const sem = document.getElementById('adminSem').value;
        const branch = document.getElementById('adminBranch').value;
        if (!sem || !branch) { showAdminMsg('Select semester & branch to delete', '#ffe0e0'); return; }
        if (syllabusDB[sem] && syllabusDB[sem][branch]) {
            delete syllabusDB[sem][branch];
            if (Object.keys(syllabusDB[sem]).length === 0) delete syllabusDB[sem];
            persistAndRefresh();
            showAdminMsg(`🗑️ Removed ${sem} - ${branch}`, '#ffe0e0');
        } else {
            showAdminMsg(`⚠️ No entry found for ${sem} / ${branch}`, '#fff3cd');
        }
    }
    
    function resetToDefault() {
        if (confirm('⚠️ WARNING: This will erase all custom PDF links and restore default syllabus. Continue?')) {
            syllabusDB = JSON.parse(JSON.stringify(DEFAULT_SYLLABUS));
            persistAndRefresh();
            showAdminMsg('🔄 Database reset to default syllabus!', '#d9efff');
        }
    }
    
    // ---------- VIEWER LOGIC ----------
    const branchSelect = document.getElementById('branch');
    const semSelect = document.getElementById('sem');
    const openBtn = document.getElementById('openBtn');
    const msgDiv = document.getElementById('msg');
    const pdfModal = document.getElementById('pdfModal');
    const pdfFrame = document.getElementById('pdfFrame');
    const modalCloseBtn = document.getElementById('modalCloseBtn');
    const modalDownloadBtn = document.getElementById('modalDownloadBtn');
    
    function showViewerMessage(text, isError = false) {
        msgDiv.style.background = isError ? '#ffe8e8' : '#eef5ff';
        msgDiv.innerHTML = text;
        setTimeout(() => {
            if(msgDiv.innerHTML === text) msgDiv.innerHTML = "✅ Choose branch & semester to view syllabus.";
            msgDiv.style.background = '#eef5ff';
        }, 5000);
    }
    
    openBtn.onclick = () => {
        const branch = branchSelect.value;
        const sem = semSelect.value;
        if (!branch || !sem) { showViewerMessage('❌ Please select both branch & semester.', true); return; }
        if (!syllabusDB[sem] || !syllabusDB[sem][branch]) {
            showViewerMessage(`❌ Syllabus not available for ${branch} - ${sem}. Use Admin panel to add.`, true);
            return;
        }
        const pdfLink = syllabusDB[sem][branch];
        pdfFrame.src = pdfLink;
        pdfModal.style.display = 'flex';
        showViewerMessage(`📄 Preview opened. You can download from modal.`);
    };
    
    function closePDFModal() { pdfModal.style.display = 'none'; pdfFrame.src = ''; }
    modalCloseBtn.onclick = closePDFModal;
    modalDownloadBtn.onclick = () => {
        const currentSrc = pdfFrame.src;
        if (!currentSrc) return;
        const a = document.createElement('a');
        a.href = currentSrc;
        a.download = `syllabus_${branchSelect.value}_${semSelect.value}.pdf`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        showViewerMessage('✅ Download started!');
    };
    
    // Developer modal
    const devModal = document.getElementById('devModal');
    const devBtn = document.getElementById('devBtn');
    const closeDevBtn = document.getElementById('closeDevModalBtn');
    devBtn.onclick = () => devModal.style.display = 'flex';
    closeDevBtn.onclick = () => devModal.style.display = 'none';
    window.onclick = (e) => { if(e.target === pdfModal) closePDFModal(); if(e.target === devModal) devModal.style.display='none'; };
    
    // TABS logic
    const tabBtns = document.querySelectorAll('.tab-btn');
    const viewerPanel = document.getElementById('viewerPanel');
    const adminPanelDiv = document.getElementById('adminPanel');
    tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            tabBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const tabId = btn.getAttribute('data-tab');
            if(tabId === 'viewer') {
                viewerPanel.classList.add('active-panel');
                adminPanelDiv.classList.remove('active-panel');
            } else {
                viewerPanel.classList.remove('active-panel');
                adminPanelDiv.classList.add('active-panel');
                renderAdminTable(); // refresh table each time admin opens
            }
        });
    });
    
    // admin event listeners
    document.getElementById('savePdfBtn').addEventListener('click', savePdfEntry);
    document.getElementById('deletePdfBtn').addEventListener('click', deletePdfEntry);
    document.getElementById('resetDefaultBtn').addEventListener('click', resetToDefault);
    
    // initial render table
    renderAdminTable();
    
    // Service worker reminder (original logic from index)
    if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/BEU-Syllabus-App/service-worker.js").catch(e=>console.log);
    }
</script>
</body>
</html>
