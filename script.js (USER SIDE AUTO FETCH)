import { db, doc, getDoc } from './firebase.js';

async function openPDF(){

    let b = branch.value;
    let s = sem.value;

    let docRef = doc(db, "syllabus", `${b}_${s}`);
    let snap = await getDoc(docRef);

    if(!snap.exists()){
        msg.innerHTML = "❌ Not available";
        return;
    }

    let url = snap.data().url;

    pdfFrame.src = url;
    pdfModal.style.display = "flex";
}
